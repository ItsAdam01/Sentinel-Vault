<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Security Audit Logs</title>
    <style>
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        .ALERT { color: red; font-weight: bold; }
        .WARN { color: orange; }
        .INFO { color: blue; }
    </style>
</head>
<body>
    <nav><a href="/vault">Back to Vault</a> | <a href="/lgout">Logout</a></nav>
    <h1>Security Audit Logs</h1>
    <table>
        <thead>
            <tr>
                <th>Timestamp</th>
                <th>Event</th>
                <th>User</th>
                <th>Severity</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            <% logs.forEach(log => { %>
                <tr>
                    <td><%= log.timestamp %></td>
                    <td><%= log.icon %> <%= log.event_type %></td>
                    <td><%= log.username || 'Anonymous' %></td>
                    <td class="<%= log.severity %>"><%= log.severity %></td>
                    <td><%= log.details %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>